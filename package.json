{
  "name": "data-consistency-checker",
  "private": true,
  "version": "1.0.0",
  "main": "main.js",
  "type": "module",
  "description": "数据一致性自动化核对工具 - 分布式系统查-发-查-比数据一致性检查",
  "author": "Taylor Ding <taylor.ding@example.com>",
  "homepage": "https://github.com/Taylor-Ding/api_post_trae",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "electron .",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.4"
  },
  "build": {
    "appId": "com.example.data-consistency-checker",
    "productName": "数据一致性自动化核对工具",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "dist/**/*",
      "public/**/*"
    ],
    "extraResources": [
      "backend/**/*",
      ".venv/**/*"
    ],
    "asar": false,
    "icon": "public/icons/api_post.svg",
    "mac": {
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": ["AppImage", "deb", "rpm"]
    }
  }
}
